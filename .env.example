# PostgreSQL
POSTGRES_DB=neomarket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App
# Docker: db:5432 | Локальная разработка: localhost:5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/neomarket
SECRET_KEY=change-me-in-production
DEBUG=true
ACCESS_TOKEN_EXPIRE_MINUTES=30
B2B_BASE_URL=http://b2b:8000
MOD_TO_B2B_SERVICE_KEY=change-me-in-production
B2B_TO_MOD_SERVICE_KEY=change-me-in-production
